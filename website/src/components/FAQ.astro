---
import type { Translation } from '../i18n/translations';

interface Props {
  t: Translation;
}

const { t } = Astro.props;

const faqStructuredData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": t.faq.items.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};
---

<section id="faq" class="py-20 px-4 sm:px-6 lg:px-8 bg-primary-50">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold text-primary-700 mb-4">
        {t.faq.title}
      </h2>
    </div>
    <div class="space-y-6">
      {t.faq.items.map(item => (
        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
          <h3 class="text-lg font-semibold text-primary-900 mb-2">{item.question}</h3>
          <p class="text-gray-600">{item.answer}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- FAQPage Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(faqStructuredData)} />
</section>
