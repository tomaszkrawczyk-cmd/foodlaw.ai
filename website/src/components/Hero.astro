---
import type { Translation } from '../i18n/translations';

interface Props {
  t: Translation;
}

const { t } = Astro.props;
---

<section class="hero-gradient pt-32 pb-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-4xl mx-auto text-center">
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
      {t.hero.headline}
    </h1>
    <p class="text-lg sm:text-xl text-primary-100 mb-10 max-w-2xl mx-auto">
      {t.hero.subheadline}
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#projects"
        class="inline-flex items-center px-8 py-3 text-base font-semibold rounded-lg bg-accent-500 text-white hover:bg-accent-600 transition-smooth shadow-lg"
      >
        {t.hero.cta}
      </a>
      <a
        href="#features"
        class="inline-flex items-center px-8 py-3 text-base font-semibold rounded-lg border-2 border-white/30 text-white hover:bg-white/10 transition-smooth"
      >
        {t.hero.ctaSecondary}
      </a>
    </div>
  </div>
</section>
