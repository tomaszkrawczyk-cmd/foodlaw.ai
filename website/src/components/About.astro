---
import type { Translation } from '../i18n/translations';

interface Props {
  t: Translation;
}

const { t } = Astro.props;
---

<section id="about" class="py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-8">
      <h2 class="text-3xl sm:text-4xl font-bold text-primary-700 mb-4">
        {t.about.title}
      </h2>
    </div>
    <div class="bg-white rounded-xl p-8 shadow-sm border border-gray-100 space-y-4">
      <p class="text-gray-700 text-lg leading-relaxed">{t.about.content}</p>
      <p class="text-gray-600 leading-relaxed">{t.about.expertise}</p>
      <p class="text-gray-600 leading-relaxed">{t.about.factual}</p>
    </div>
  </div>
</section>
