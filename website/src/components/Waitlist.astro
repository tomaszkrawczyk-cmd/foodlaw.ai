---
import type { Translation } from '../i18n/translations';

interface Props {
  t: Translation;
}

const { t } = Astro.props;
---

<section id="waitlist" class="py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="text-3xl sm:text-4xl font-bold text-primary-700 mb-4">
      {t.waitlist.title}
    </h2>
    <p class="text-lg text-gray-600 mb-8">
      {t.waitlist.subtitle}
    </p>
    <form action="#" method="POST" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
      <input
        type="email"
        name="email"
        required
        placeholder={t.waitlist.emailPlaceholder}
        class="flex-1 px-4 py-3 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent text-gray-900"
      />
      <button
        type="submit"
        class="px-6 py-3 rounded-lg bg-accent-500 text-white font-semibold hover:bg-accent-600 transition-smooth shadow-md"
      >
        {t.waitlist.submit}
      </button>
    </form>
    <p class="text-sm text-gray-500 mt-4">{t.waitlist.success}</p>
  </div>
</section>
