---
import type { Translation } from '../i18n/translations';

interface Props {
  t: Translation;
}

const { t } = Astro.props;
---

<section id="waitlist" class="py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="text-3xl sm:text-4xl font-bold text-primary-700 mb-4">
      {t.waitlist.title}
    </h2>
    <p class="text-lg text-gray-600 mb-8">
      {t.waitlist.subtitle}
    </p>
    <form id="waitlist-form" data-netlify="true" name="waitlist" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
      <input
        type="email"
        name="email"
        required
        placeholder={t.waitlist.emailPlaceholder}
        class="flex-1 px-4 py-3 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent text-gray-900"
      />
      <button
        type="submit"
        class="px-6 py-3 rounded-lg bg-accent-500 text-white font-semibold hover:bg-accent-600 transition-smooth shadow-md"
      >
        {t.waitlist.submit}
      </button>
    </form>
    <p id="waitlist-success" class="text-sm text-gray-500 mt-4 hidden">{t.waitlist.success}</p>
  </div>
</section>

<script>
  const form = document.getElementById('waitlist-form') as HTMLFormElement | null;
  const successMsg = document.getElementById('waitlist-success');

  if (form && successMsg) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const emailInput = form.querySelector('input[name="email"]') as HTMLInputElement | null;
      const email = emailInput?.value?.trim();
      if (email) {
        const stored = JSON.parse(localStorage.getItem('waitlist_emails') || '[]');
        stored.push(email);
        localStorage.setItem('waitlist_emails', JSON.stringify(stored));
      }
      form.classList.add('hidden');
      successMsg.classList.remove('hidden');
    });
  }
</script>
