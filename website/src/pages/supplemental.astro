---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import { translations } from '../i18n/translations';

const t = translations.pl;
---

<Layout
  t={t}
  pageTitle="Narzędzia AI dla prawa żywnościowego - supplemental.pl"
  pageDescription="Narzędzia AI wspomagające pracę z prawem żywnościowym. Automatyzacja badań prawnych, monitoring regulacyjny i analiza dokumentów. Ponad 15 lat doświadczenia połączone z AI."
  canonical="https://foodlaw.ai/supplemental/"
>
  <!-- Header / Nav -->
  <nav class="absolute top-0 left-0 right-0 z-10 py-6 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto flex items-center justify-between">
      <a href="/" class="text-xl font-bold text-white">
        FOODLAW<span class="text-accent-400">.ai</span>
      </a>
      <a
        href="/"
        class="text-sm text-white/80 hover:text-white transition-smooth"
      >
        &larr; Strona główna
      </a>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="hero-gradient pt-32 pb-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-accent-400 font-semibold text-sm uppercase tracking-wider mb-4">supplemental.pl</p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
        Narzędzia AI dla prawa żywnościowego
      </h1>
      <p class="text-lg sm:text-xl text-primary-100 mb-10 max-w-2xl mx-auto">
        Wykorzystaj sztuczną inteligencję do analizy przepisów, monitorowania zmian regulacyjnych i automatyzacji badań prawnych w branży spożywczej.
      </p>
      <a
        href="/"
        class="inline-flex items-center px-8 py-3 text-base font-semibold rounded-lg bg-accent-500 text-white hover:bg-accent-600 transition-smooth shadow-lg"
      >
        Przejdź do FOODLAW.ai
      </a>
    </div>
  </section>

  <!-- Messaging Pillars -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 bg-primary-50">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-3xl font-bold text-center text-primary-900 mb-4">Dlaczego AI w prawie żywnościowym?</h2>
      <p class="text-center text-primary-600 mb-12 max-w-2xl mx-auto">
        Połączenie ponad 15 lat doświadczenia w prawie żywnościowym z najnowszymi technologiami AI.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Pillar 1: Speed -->
        <div class="bg-white rounded-xl p-8 shadow-sm card-hover">
          <div class="w-12 h-12 bg-accent-100 rounded-lg flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-primary-900 mb-3">Szybkość działania</h3>
          <p class="text-primary-600">
            AI przetwarza przepisy natychmiastowo. Analiza, która dotychczas zajmowała godziny, teraz trwa sekundy. Automatyczne przeszukiwanie bazy ponad 20 rozporządzeń UE i polskich aktów prawnych.
          </p>
        </div>

        <!-- Pillar 2: Confidence & Experience -->
        <div class="bg-white rounded-xl p-8 shadow-sm card-hover">
          <div class="w-12 h-12 bg-accent-100 rounded-lg flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-primary-900 mb-3">Pewność i doświadczenie</h3>
          <p class="text-primary-600">
            Ponad 15 lat specjalizacji w prawie żywnościowym połączone z AI. Narzędzia oparte na wiedzy obejmującej 19+ obszarów prawa żywnościowego - od suplementów diety po novel food.
          </p>
        </div>

        <!-- Pillar 3: Competitive Pricing -->
        <div class="bg-white rounded-xl p-8 shadow-sm card-hover">
          <div class="w-12 h-12 bg-accent-100 rounded-lg flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-primary-900 mb-3">Konkurencyjne ceny</h3>
          <p class="text-primary-600">
            Dzięki opanowaniu technologii AI oferujemy usługi w bardzo konkurencyjnych cenach. Automatyzacja procesów pozwala na obniżenie kosztów bez utraty jakości.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- AI Tools Section -->
  <section class="py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-3xl font-bold text-center text-primary-900 mb-4">Nasze narzędzia AI</h2>
      <p class="text-center text-primary-600 mb-12 max-w-2xl mx-auto">
        Zestaw specjalistycznych narzędzi wspomagających pracę z prawem żywnościowym.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Tool 1: Automated Legal Research -->
        <div class="border border-primary-100 rounded-xl p-6 card-hover">
          <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-primary-900 mb-2">Zautomatyzowane badania prawne</h3>
          <p class="text-primary-600 text-sm">
            Automatyczne przeszukiwanie i analiza przepisów prawa żywnościowego UE i polskiego. AI identyfikuje odpowiednie regulacje i przedstawia kluczowe wymagania.
          </p>
        </div>

        <!-- Tool 2: Regulatory Monitoring -->
        <div class="border border-primary-100 rounded-xl p-6 card-hover">
          <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-primary-900 mb-2">Monitoring regulacyjny</h3>
          <p class="text-primary-600 text-sm">
            Śledzenie zmian w przepisach prawa żywnościowego. Automatyczne powiadomienia o nowych regulacjach, nowelizacjach i orzeczeniach wpływających na Twoją działalność.
          </p>
        </div>

        <!-- Tool 3: Document Analysis -->
        <div class="border border-primary-100 rounded-xl p-6 card-hover">
          <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-primary-900 mb-2">Analiza dokumentów</h3>
          <p class="text-primary-600 text-sm">
            AI analizuje etykiety, specyfikacje produktów i dokumentację pod kątem zgodności z przepisami prawa żywnościowego. Szybka identyfikacja potencjalnych niezgodności.
          </p>
        </div>

        <!-- Tool 4: Case Law Database -->
        <div class="border border-primary-100 rounded-xl p-6 card-hover">
          <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-primary-900 mb-2">Baza orzecznictwa</h3>
          <p class="text-primary-600 text-sm">
            Dostęp do orzeczeń NSA, WSA, TSUE oraz decyzji GIS z zakresu prawa żywnościowego. AI wyszukuje i analizuje relewantne orzeczenia dla Twojej sprawy.
          </p>
        </div>

        <!-- Tool 5: EU Regulations -->
        <div class="border border-primary-100 rounded-xl p-6 card-hover">
          <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-primary-900 mb-2">Rozporządzenia UE</h3>
          <p class="text-primary-600 text-sm">
            Pełna baza ponad 20 rozporządzeń UE dotyczących prawa żywnościowego. Od ogólnego prawa żywnościowego po szczegółowe regulacje branży suplementów diety.
          </p>
        </div>

        <!-- Tool 6: Expert Consultations -->
        <div class="border border-primary-100 rounded-xl p-6 card-hover">
          <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-primary-900 mb-2">Wsparcie eksperckie</h3>
          <p class="text-primary-600 text-sm">
            AI wspomagane wiedzą eksperta z 15+ letnim doświadczeniem. Odpowiedzi uwzględniające praktyczne aspekty stosowania prawa żywnościowego w Polsce.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Screenshots Section -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 bg-white">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-center text-primary-900 mb-4">Nasze narzędzia w akcji</h2>
      <p class="text-center text-primary-600 mb-12 max-w-2xl mx-auto">
        Kliknij na zrzut ekranu, aby przejść do wybranego narzędzia.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <a href="https://app.foodlaw.ai" target="_blank" rel="noopener noreferrer" class="group">
          <div class="rounded-xl overflow-hidden shadow-sm border border-primary-100 card-hover">
            <img src="/images/app-claims.png" alt="app.foodlaw.ai - Health Claims" class="w-full aspect-video object-cover" />
          </div>
          <p class="mt-3 text-sm text-primary-600 text-center font-medium group-hover:text-primary-900 transition-smooth">
            app.foodlaw.ai - Oświadczenia zdrowotne
          </p>
        </a>
        <a href="https://nutrimetr.foodlaw.ai" target="_blank" rel="noopener noreferrer" class="group">
          <div class="rounded-xl overflow-hidden shadow-sm border border-primary-100 card-hover">
            <img src="/images/nutrimetr.png" alt="Nutrimetr - Analiza składu żywności" class="w-full aspect-video object-cover" />
          </div>
          <p class="mt-3 text-sm text-primary-600 text-center font-medium group-hover:text-primary-900 transition-smooth">
            Nutrimetr - Analiza składu żywności
          </p>
        </a>
        <a href="https://www.supplemental.pl" target="_blank" rel="noopener noreferrer" class="group">
          <div class="rounded-xl overflow-hidden shadow-sm border border-primary-100 card-hover">
            <img src="/images/supplemental-ai.png" alt="Asystent AI na supplemental.pl" class="w-full aspect-video object-cover" />
          </div>
          <p class="mt-3 text-sm text-primary-600 text-center font-medium group-hover:text-primary-900 transition-smooth">
            Asystent AI na supplemental.pl
          </p>
        </a>
      </div>
    </div>
  </section>

  <!-- Reference to supplemental.pl -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 bg-primary-50">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-primary-900 mb-4">O Supple Mental</h2>
      <p class="text-primary-600 text-lg mb-6">
        Narzędzia FOODLAW.ai powstały w ramach firmy
        <a href="https://www.supplemental.pl" target="_blank" rel="noopener noreferrer" class="text-accent-600 font-semibold hover:text-accent-700 underline">
          supplemental.pl
        </a>
        - specjalizującej się w prawie żywnościowym z ponad 15-letnim doświadczeniem.
        Wykorzystujemy technologię AI, aby zapewnić szybkie, pewne i konkurencyjne cenowo rozwiązania dla branży spożywczej.
      </p>
      <a
        href="https://www.supplemental.pl"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center px-6 py-3 text-base font-semibold rounded-lg border-2 border-accent-500 text-accent-600 hover:bg-accent-500 hover:text-white transition-smooth"
      >
        Odwiedź supplemental.pl &rarr;
      </a>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 hero-gradient">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Gotowy na AI w prawie żywnościowym?</h2>
      <p class="text-primary-100 mb-8 text-lg">
        Sprawdź FOODLAW.ai i przekonaj się, jak sztuczna inteligencja może usprawnić Twoją pracę z przepisami prawa żywnościowego.
      </p>
      <a
        href="/"
        class="inline-flex items-center px-8 py-4 text-lg font-semibold rounded-lg bg-accent-500 text-white hover:bg-accent-600 transition-smooth shadow-lg"
      >
        Przejdź do FOODLAW.ai
      </a>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 bg-white">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-primary-900 mb-4">Kontakt</h2>
      <p class="text-primary-600 text-lg mb-8">
        Masz pytania dotyczące naszych narzędzi AI lub potrzebujesz wsparcia w zakresie prawa żywnościowego? Skontaktuj się z nami.
      </p>
      <div class="bg-primary-50 rounded-xl p-8 inline-block">
        <p class="text-primary-900 font-semibold text-lg mb-2">Tomasz Krawczyk</p>
        <p class="text-primary-600 mb-4">Prawo żywnościowe &bull; AI &bull; supplemental.pl</p>
        <a
          href="mailto:kontakt@supplemental.pl"
          class="inline-flex items-center text-accent-600 font-semibold hover:text-accent-700 transition-smooth"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
          </svg>
          kontakt@supplemental.pl
        </a>
        <div class="mt-4">
          <a
            href="https://www.supplemental.pl"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center text-primary-600 hover:text-primary-900 transition-smooth text-sm"
          >
            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
            </svg>
            www.supplemental.pl
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer t={t} />
</Layout>
